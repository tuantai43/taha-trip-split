[debug] [2026-03-23T09:47:59.091Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/taha-tripsplit-61618/rulesets {"name":"projects/taha-tripsplit-61618/rulesets/12c83df7-bd61-4a5d-9172-654df91b53ee","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(tripId) {\n      return signedIn() &&\n        get(/databases/$(database)/documents/trips/$(tripId)).data.createdBy == request.auth.uid;\n    }\n\n    match /users/{userId} {\n      allow read, delete: if signedIn() && request.auth.uid == userId;\n      allow create: if signedIn() &&\n        request.auth.uid == userId &&\n        request.resource.data.email is string &&\n        request.resource.data.displayName is string;\n      allow update: if signedIn() &&\n        request.auth.uid == userId &&\n        (!('email' in request.resource.data) || request.resource.data.email is string) &&\n        (!('displayName' in request.resource.data) || request.resource.data.displayName is string) &&\n        (!('avatarUrl' in request.resource.data) || request.resource.data.avatarUrl == null || request.resource.data.avatarUrl is string);\n    }\n\n    match /trips/{tripId} {\n      allow read, delete: if isOwner(tripId);\n      allow create: if signedIn() &&\n        request.resource.data.createdBy == request.auth.uid &&\n        request.resource.data.name is string &&\n        request.resource.data.currencyCode is string &&\n        request.resource.data.status is string &&\n        request.resource.data.shareEnabled is bool;\n      allow update: if isOwner(tripId) &&\n        request.resource.data.createdBy == resource.data.createdBy;\n    }\n\n    match /trips/{tripId}/members/{memberId} {\n      allow read, write: if isOwner(tripId);\n    }\n\n    match /trips/{tripId}/transactions/{transactionId} {\n      allow read, write: if isOwner(tripId);\n    }\n\n    match /trips/{tripId}/transactions/{transactionId}/splits/{splitId} {\n      allow read, write: if isOwner(tripId);\n    }\n  }\n}\n","name":"firebase.rules"}]},"createTime":"2026-03-23T09:47:58.978239Z","metadata":{"services":["cloud.firestore"]}}
