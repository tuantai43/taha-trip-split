r(tripId) &&\n        request.resource.data.createdBy == resource.data.createdBy &&\n        validTripStatus(request.resource.data.status);\n    }\n\n    match /trips/{tripId}/members/{memberId} {\n      allow read: if isOwner(tripId);\n      allow create, update: if isOwner(tripId) &&\n        request.resource.data.displayName is string &&\n        validMemberRole(request.resource.data.role) &&\n        request.resource.data.isGuest is bool &&\n        (\n          request.resource.data.role == \"member\" ||\n          (\n            request.resource.data.role == \"owner\" &&\n            request.resource.data.userId == request.auth.uid &&\n            request.resource.data.isGuest == false\n          )\n        );\n      allow delete: if isOwner(tripId);\n    }\n\n    match /trips/{tripId}/transactions/{transactionId} {\n      allow read, write: if isOwner(tripId);\n    }\n\n    match /trips/{tripId}/transactions/{transactionId}/splits/{splitId} {\n      allow read, write: if isOwner(tripId);\n    }\n  }\n}\n","name":"firebase.rules"}]},"createTime":"2026-03-23T10:23:08.661647Z","metadata":{"services":["cloud.firestore"]}}
